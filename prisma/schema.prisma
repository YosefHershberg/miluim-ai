generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CommanderRank {
  NONE
  PLATOON_COMMANDER    // מ"מ/מ"פ
  DEPUTY_COMPANY       // סמ"פ/סמג"ד
  COMPANY_COMMANDER    // מ"פ/סג"ד
  BATTALION_COMMANDER  // מג"ד
}

enum EmploymentType {
  SALARIED       // שכיר
  SELF_EMPLOYED  // עצמאי
  UNEMPLOYED     // לא עובד
  STUDENT        // סטודנט
}

enum ChildrenUnder18 {
  ZERO
  ONE_TO_THREE
  FOUR_PLUS
}

enum ServiceRole {
  COMBAT              // לוחם
  TERRITORIAL_DEFENSE // הגנה מרחבית
  SUPPORT             // תומך/ג'וב/עורפי
}

enum ActivityTier {
  ALEPH_PLUS  // א+
  ALEPH       // א
  BET         // ב
  GIMEL       // ג
  DALET       // ד
  HE          // ה
}

model UserProfile {
  id                 String          @id @default(uuid())
  userId             String          @unique // maps to auth.users.id from Supabase
  fullName           String
  dateOfBirth        DateTime        @db.Date
  idNumber           String          @unique
  commanderRank      CommanderRank   @default(NONE)
  serviceRole        ServiceRole?
  activityTier       ActivityTier?
  employmentType     EmploymentType
  monthlyGrossSalary Decimal?        @db.Decimal(10, 2)
  annualGrossIncome  Decimal?        @db.Decimal(12, 2)
  hasChildUnder14    Boolean         @default(false)
  childrenUnder18    ChildrenUnder18 @default(ZERO)
  isStudent          Boolean         @default(false)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  servicePeriods ServicePeriod[]

  @@map("user_profiles")
}

model ServicePeriod {
  id               String        @id @default(uuid())
  userProfileId    String
  startDate        DateTime      @db.Date
  endDate          DateTime      @db.Date
  totalDays        Int
  isEmergencyOrder Boolean       @default(true)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  userProfile UserProfile @relation(fields: [userProfileId], references: [id], onDelete: Cascade)

  @@map("service_periods")
}
